# Copy to fastlane/.env (gitignored) and fill in REAL values there. fastlane auto-loads .env.
# Keep real key IDs/paths out of this committed example — they live only in your local .env.
# These point at key FILES on disk; the files themselves are the secrets and stay out of git.

# --- iOS: App Store Connect API key (.p8) ---
# Values from App Store Connect > Users and Access > Integrations (also in your password manager).
ASC_KEY_ID=XXXXXXXXXX
ASC_ISSUER_ID=00000000-0000-0000-0000-000000000000
ASC_KEY_FILEPATH=/absolute/path/to/AuthKey_XXXXXXXXXX.p8

# --- Android: Google Play service-account JSON ---
# Create in Google Cloud Console, grant access in Play Console > Users & permissions.
PLAY_JSON_KEY_FILEPATH=/absolute/path/to/voxrider-play-sa.json
