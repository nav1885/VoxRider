<?xml version="1.0" encoding="utf-8"?>
<!--
  Launcher icon foreground: white rear-view car silhouette + green radar arcs.
  Perspective: cyclist looking back at an approaching car.
  108×108 adaptive icon viewport — all content within 18–90 safe zone.
-->
<vector xmlns:android="http://schemas.android.com/apk/res/android"
    android:width="108dp"
    android:height="108dp"
    android:viewportWidth="108"
    android:viewportHeight="108">

    <!-- ── Car silhouette (white, rear view) ── -->

    <!-- Cabin / roof -->
    <path
        android:fillColor="#FFFFFF"
        android:pathData="M41,22 h26 a5,5 0 0,1 5,5 v4 a5,5 0 0,1 -5,5 h-26 a5,5 0 0,1 -5,-5 v-4 a5,5 0 0,1 5,-5 Z" />

    <!-- Main body -->
    <path
        android:fillColor="#FFFFFF"
        android:pathData="M26,33 h56 a4,4 0 0,1 4,4 v12 a4,4 0 0,1 -4,4 h-56 a4,4 0 0,1 -4,-4 v-12 a4,4 0 0,1 4,-4 Z" />

    <!-- Rear bumper -->
    <path
        android:fillColor="#FFFFFF"
        android:pathData="M27,50 h54 a3,3 0 0,1 3,3 v2 a3,3 0 0,1 -3,3 h-54 a3,3 0 0,1 -3,-3 v-2 a3,3 0 0,1 3,-3 Z" />

    <!-- ── Radar arcs (green, opening downward — arcs fan toward the cyclist) ── -->

    <!-- Inner arc -->
    <path
        android:strokeColor="#22C55E"
        android:strokeWidth="4.5"
        android:strokeLineCap="round"
        android:fillColor="@android:color/transparent"
        android:pathData="M42,66 A14,14 0 0,0 66,66" />

    <!-- Middle arc -->
    <path
        android:strokeColor="#22C55E"
        android:strokeWidth="4.5"
        android:strokeLineCap="round"
        android:fillColor="@android:color/transparent"
        android:pathData="M33,73 A23,23 0 0,0 75,73" />

    <!-- Outer arc -->
    <path
        android:strokeColor="#22C55E"
        android:strokeWidth="4.5"
        android:strokeLineCap="round"
        android:fillColor="@android:color/transparent"
        android:pathData="M24,80 A32,32 0 0,0 84,80" />

</vector>
