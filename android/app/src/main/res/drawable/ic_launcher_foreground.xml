<?xml version="1.0" encoding="utf-8"?>
<!--
  Launcher icon foreground: radar arcs + rider dot.
  Designed for 108×108 adaptive icon viewport (safe zone 18–90).
  Scaled 3.5× from the 24×24 notification icon, centred at (54, 54).
-->
<vector xmlns:android="http://schemas.android.com/apk/res/android"
    android:width="108dp"
    android:height="108dp"
    android:viewportWidth="108"
    android:viewportHeight="108">

    <!-- Rider / bike position dot -->
    <path
        android:fillColor="#22C55E"
        android:pathData="M54,40.5 a5.25,5.25 0 1,1 0,0.001 Z" />

    <!-- Inner arc -->
    <path
        android:strokeColor="#22C55E"
        android:strokeWidth="4.9"
        android:strokeLineCap="round"
        android:fillColor="@android:color/transparent"
        android:pathData="M38.25,51 A21,21 0 0,1 69.75,51" />

    <!-- Middle arc -->
    <path
        android:strokeColor="#22C55E"
        android:strokeWidth="4.9"
        android:strokeLineCap="round"
        android:fillColor="@android:color/transparent"
        android:pathData="M27.75,59.75 A31.5,31.5 0 0,1 80.25,59.75" />

    <!-- Outer arc -->
    <path
        android:strokeColor="#22C55E"
        android:strokeWidth="4.9"
        android:strokeLineCap="round"
        android:fillColor="@android:color/transparent"
        android:pathData="M19,68.5 A42,42 0 0,1 89,68.5" />

</vector>
