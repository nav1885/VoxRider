<?xml version="1.0" encoding="utf-8"?>
<!-- Notification icon: radar arc with centre dot — monochrome, white-on-transparent -->
<vector xmlns:android="http://schemas.android.com/apk/res/android"
    android:width="24dp"
    android:height="24dp"
    android:viewportWidth="24"
    android:viewportHeight="24">

    <!-- Centre dot (bike / rider position) -->
    <path
        android:fillColor="#FFFFFF"
        android:pathData="M12,11 a1.5,1.5 0 1,1 0,0.001 Z" />

    <!-- Inner arc (~3m) -->
    <path
        android:strokeColor="#FFFFFF"
        android:strokeWidth="1.4"
        android:strokeLineCap="round"
        android:fillColor="@android:color/transparent"
        android:pathData="M7.5,14 A6,6 0 0,1 16.5,14" />

    <!-- Middle arc (~10m) -->
    <path
        android:strokeColor="#FFFFFF"
        android:strokeWidth="1.4"
        android:strokeLineCap="round"
        android:fillColor="@android:color/transparent"
        android:pathData="M4.5,16.5 A9,9 0 0,1 19.5,16.5" />

    <!-- Outer arc (~20m) -->
    <path
        android:strokeColor="#FFFFFF"
        android:strokeWidth="1.4"
        android:strokeLineCap="round"
        android:fillColor="@android:color/transparent"
        android:pathData="M2,19 A12,12 0 0,1 22,19" />

</vector>
